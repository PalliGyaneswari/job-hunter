# ── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jobpulse_db
DB_USER=root
DB_PASSWORD=your_mysql_password

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_characters
JWT_EXPIRES_IN=7d

# Admin login — change these immediately
ADMIN_USERNAME=admin
# Generate bcrypt hash: node -e "const b=require('bcryptjs');console.log(b.hashSync('your_password',12))"
ADMIN_PASSWORD_HASH=$2a$12$PLACEHOLDER_REPLACE_WITH_REAL_BCRYPT_HASH

# ── API Keys ─────────────────────────────────────────────────────────────────
# Adzuna: https://developer.adzuna.com/ (free tier)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# JSearch via RapidAPI: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch (free tier)
RAPIDAPI_KEY=

# Jooble: https://jooble.org/api/about (free, requires email request)
JOOBLE_API_KEY=

# ── Cron Schedule ─────────────────────────────────────────────────────────────
# Default: runs at 2 AM every day. Uses standard 5-field cron syntax.
CRON_SCHEDULE=0 2 * * *

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# Frontend URL (comma-separated if multiple)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
