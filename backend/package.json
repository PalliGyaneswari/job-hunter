{
  "name": "jobpulse-backend",
  "version": "1.0.0",
  "description": "JobPulse personal job-aggregator — backend API server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node src/db/seed.js",
    "migrate": "node src/db/migrate.js",
    "build": "cd ../frontend && npm install --include=dev && npm run build",
    "postinstall": "cd ../frontend && npm install --include=dev && npm run build"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.10.1",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.7.0",
    "fuse.js": "^7.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
